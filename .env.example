# ── Ria AI 어시스턴트 환경 설정 ──────────────────────
# 이 파일을 .env 로 복사한 뒤 환경에 맞게 수정하세요.
# cp .env.example .env

# ── LLM (Ollama) ─────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# LLM_MODEL=bnksys/eeve:10.8b-korean-instruct-q5_k_m-v1
# LLM_TIMEOUT=120

# ── 연산 디바이스 (cuda / mps / cpu) ─────────────────
# DEVICE=cuda

# ── GPT-SoVITS ───────────────────────────────────────
# SOVITS_DIR=C:\My\tts\GPT-SoVITS-v2pro-20250604
# SOVITS_API_URL=http://127.0.0.1:9880
# SOVITS_REF_AUDIO=sound_model\segment_0000.wav
# SOVITS_REF_TEXT=
# SOVITS_LANG=ko

# 학습된 가중치가 있으면 여기에 경로 지정 (없으면 pretrained 사용)
# SOVITS_GPT_WEIGHTS=GPT_weights_v2Pro/ria-e10.ckpt
# SOVITS_WEIGHTS=SoVITS_weights_v2Pro/ria_e8_s360.pth

# ── STT ──────────────────────────────────────────────
# STT_MODEL=base

# ── NAS 경로 ─────────────────────────────────────────
# NAS_PATH=\\NAS

# ── Firebase (선택) ──────────────────────────────────
# FIREBASE_KEY_PATH=

# ── 로그 ─────────────────────────────────────────────
# LOG_LEVEL=DEBUG
